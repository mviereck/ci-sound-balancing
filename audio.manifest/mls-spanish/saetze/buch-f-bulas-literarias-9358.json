  "items": [
    {
      "id": "11266_9358_000000",
      "text": "un arroyo añadió sí padre mío es una furia lo que ese hombre miente yo voy a mi camino no censuro y con todo ha fingido que murmuro",
      "audio": "test/audio/11266/9358/11266_9358_000000.opus",
      "tags": {
        "speaker_id": "mls-es-11266",
        "gender": "w",
        "book_id": "9358",
        "split": "test",
