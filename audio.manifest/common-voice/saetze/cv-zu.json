  "items": [
    {
      "id": "39879169",
      "text": "Iqembu ngalinye lisebenza nothisha kabili ngesonto.",
      "audio": "zu/unknown/zu_u_39879169.mp3",
      "tags": {
        "source_item_id": "39879169",
        "gender": "u",
        "up_votes": 1,
        "down_votes": 0
      },
      "duration": 5.22
    },
    {
      "id": "39879094",
      "text": "Bahleli kuliphi igumbi lendlu laba abakhulumayo.",
      "audio": "zu/unknown/zu_u_39879094.mp3",
      "tags": {
        "source_item_id": "39879094",
        "gender": "u",
        "up_votes": 1,
        "down_votes": 0
      },
      "duration": 4.61
    },
    {
      "id": "39879159",
      "text": "Izimayini ziqashe abantu abevile kwisigamu sesigidi.",
      "audio": "zu/unknown/zu_u_39879159.mp3",
      "tags": {
        "source_item_id": "39879159",
        "gender": "u",
        "up_votes": 0,
        "down_votes": 0
      },
      "duration": 6.34
    },
    {
      "id": "39879162",
      "text": "Izimbali zafa sabona umdumba omncane kabhontshisi.",
      "audio": "zu/unknown/zu_u_39879162.mp3",
      "tags": {
        "source_item_id": "39879162",
        "gender": "u",
        "up_votes": 0,
        "down_votes": 0
      },
      "duration": 6.05
    },
    {
      "id": "39879116",
      "text": "Kwangithatha iminyaka ukuba ngixoxele abazali bami.",
      "audio": "zu/unknown/zu_u_39879116.mp3",
      "tags": {
        "source_item_id": "39879116",
        "gender": "u",
        "up_votes": 0,
        "down_votes": 0
      },
      "duration": 4.14
    },
    {
      "id": "39879160",
      "text": "Umqashi wakho kufanele akudedele uye enkantolo.",
      "audio": "zu/unknown/zu_u_39879160.mp3",
      "tags": {
        "source_item_id": "39879160",
        "gender": "u",
        "up_votes": 0,
        "down_votes": 0
      },
      "duration": 4.61
    },
    {
      "id": "39879152",
      "text": "Ababaningi abantu abangaphila kulo msebenzi wenu.",
      "audio": "zu/unknown/zu_u_39879152.mp3",
      "tags": {
        "source_item_id": "39879152",
        "gender": "u",
        "up_votes": 0,
        "down_votes": 0
      },
      "duration": 4.9
    },
    {
      "id": "39879126",
      "text": "Ngeke zamukelwe izicelo ezifike emva kwalolu suku.",
      "audio": "zu/unknown/zu_u_39879126.mp3",
      "tags": {
        "source_item_id": "39879126",
        "gender": "u",
        "up_votes": 0,
        "down_votes": 0
      },
      "duration": 5.15
    },
    {
      "id": "39879096",
      "text": "Abafundi babhekisa phansi amakhadi abo ezinombolo.",
      "audio": "zu/unknown/zu_u_39879096.mp3",
      "tags": {
        "source_item_id": "39879096",
        "gender": "u",
        "up_votes": 0,
