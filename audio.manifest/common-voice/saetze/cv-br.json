  "items": [
    {
      "id": "17333698",
      "text": "Marc'hadmatoc'h a-leizh eo ar pellgomzer-mañ eget hennezh.",
      "audio": "br/unknown/br_u_17333698.mp3",
      "tags": {
        "source_item_id": "17333698",
        "gender": "u"
