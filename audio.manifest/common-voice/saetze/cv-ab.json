  "items": [
    {
      "id": "22261147",
      "text": "Уи Аҟәырҟан, Аллаҳ ида даҽаӡәы шәимҵамхырхәарц азоуп.",
      "audio": "ab/unknown/ab_u_22261147.mp3",
      "tags": {
        "source_item_id": "22261147",
        "gender": "u",
        "up_votes": 2,
        "down_votes": 0
      },
      "duration": 6.14
    },
    {
      "id": "27190037",
      "text": "Уи иагьазхаҳҵеит. Уажәшьҭа ҳанцәа зынӡа аваҟәыла диваҳаргылаӡом.",
      "audio": "ab/unknown/ab_u_27190037.mp3",
      "tags": {
        "source_item_id": "27190037",
        "gender": "u",
        "up_votes": 2,
        "down_votes": 0
      },
      "duration": 7.96
    },
    {
      "id": "27271505",
      "text": "Аҵыхәтәаны ҳацхыраара рыхьӡаны аиааира згазгьы дара ракәхеит.",
      "audio": "ab/unknown/ab_u_27271505.mp3",
      "tags": {
        "source_item_id": "27271505",
        "gender": "u",
        "up_votes": 2,
        "down_votes": 0
      },
      "duration": 6.52
    },
    {
      "id": "29229233",
      "text": "Еиҳа еиӷьуп ҳәа сгәы иаанагоит.",
      "audio": "ab/unknown/ab_u_29229233.mp3",
      "tags": {
        "source_item_id": "29229233",
        "gender": "u",
        "up_votes": 2,
        "down_votes": 0
      },
      "duration": 4.82
    },
    {
      "id": "29231919",
      "text": "Агәыр аларкшозшәа ихы-иҿы ацәа ахԥаны ицон.",
      "audio": "ab/unknown/ab_u_29231919.mp3",
      "tags": {
        "source_item_id": "29231919",
        "gender": "u",
        "up_votes": 2,
        "down_votes": 1
      },
      "duration": 6.91
    },
    {
      "id": "29257487",
      "text": "Ҽнак шьыжьымҭанк, амра аҩыҵхахамҭаз, ҳәаа змаӡамыз сакарак ҳнықәгылт.",
      "audio": "ab/unknown/ab_u_29257487.mp3",
      "tags": {
        "source_item_id": "29257487",
        "gender": "u",
        "up_votes": 2,
        "down_votes": 0
      },
      "duration": 8.39
    },
    {
      "id": "29259996",
      "text": "Ҳаргьы, ишуҳәаҵәҟьо еиԥш, хьаак ҳамаӡамкәа ҳаҟам.",
      "audio": "ab/unknown/ab_u_29259996.mp3",
      "tags": {
        "source_item_id": "29259996",
        "gender": "u",
        "up_votes": 2,
        "down_votes": 0
      },
      "duration": 5.58
    },
    {
      "id": "29262409",
      "text": "Уи ашьҭахь амшқәа акыр цеит.",
      "audio": "ab/unknown/ab_u_29262409.mp3",
      "tags": {
        "source_item_id": "29262409",
        "gender": "u",
        "up_votes": 2,
        "down_votes": 0
      },
      "duration": 3.92
    },
    {
      "id": "29262456",
      "text": "Убри дшоурысыз анеилыркаа, ишнеиуаз доурышьҭит.",
      "audio": "ab/unknown/ab_u_29262456.mp3",
      "tags": {
        "source_item_id": "29262456",
        "gender": "u",
        "up_votes": 2,
        "down_votes": 0
      },
      "duration": 5.62
    },
    {
      "id": "29271384",
      "text": "Ацынҵәарах еиқәыхьшәашәа ишьҭоуп, игәаӷьны сзалакьысуам.",
      "audio": "ab/unknown/ab_u_29271384.mp3",
      "tags": {
        "source_item_id": "29271384",
        "gender": "u",
        "up_votes": 2,
        "down_votes": 0
      },
      "duration": 8.57
    }
  ]
}
