    },
    {
      "id": "39809233",
      "text": "Beplanning is 'n dinamiese proses wat voorsiening maak vir aanpassing as gevolg van toestande.",
      "audio": "af/unknown/af_u_39809233_capetonian.mp3",
      "tags": {
        "source_item_id": "39809233",
