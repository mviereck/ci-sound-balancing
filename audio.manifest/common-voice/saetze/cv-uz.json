  "items": [
    {
      "id": "28907245",
      "text": "Bundan tashqari puxta jamlangan kutubxona bor.",
      "audio": "uz/unknown/uz_u_28907245.mp3",
      "tags": {
        "source_item_id": "28907245",
        "gender": "u"
      },
      "duration": 5.44
    },
    {
      "id": "28937686",
      "text": "Ayniqsa Toshkent arxitektorlariga mos keladi.",
      "audio": "uz/unknown/uz_u_28937686.mp3",
      "tags": {
        "source_item_id": "28937686",
        "gender": "u"
      },
      "duration": 4.5
    },
    {
      "id": "28966370",
      "text": "Yana shu ishlari uchun mukofotlarga loyiq.",
      "audio": "uz/unknown/uz_u_28966370.mp3",
      "tags": {
        "source_item_id": "28966370",
        "gender": "u"
      },
      "duration": 3.42
    },
    {
      "id": "29262655",
      "text": "Hududlarda aholining yashash sharoitini yaxshilash uchun urbanizatsiya siyosatini yanada takomillashtiramiz.",
      "audio": "uz/unknown/uz_u_29262655.mp3",
      "tags": {
        "source_item_id": "29262655",
        "gender": "u"
      },
      "duration": 8.14
    },
    {
      "id": "29315864",
      "text": "Vujudi zindondir, vujudi – qamoq.",
      "audio": "uz/unknown/uz_u_29315864.mp3",
      "tags": {
        "source_item_id": "29315864",
        "gender": "u"
      },
      "duration": 5.69
    },
    {
      "id": "29420863",
      "text": "Statistika kimga tayyorlanganiga qarab ikki turga bo'linadi:",
      "audio": "uz/unknown/uz_u_29420863.mp3",
      "tags": {
        "source_item_id": "29420863",
        "gender": "u"
      },
      "duration": 5.4
    },
    {
      "id": "29571005",
      "text": "mahsulot narxi dehqonni kuydiradigan darajada pastlashiga yo‘l qo‘ymaslik",
      "audio": "uz/unknown/uz_u_29571005.mp3",
      "tags": {
        "source_item_id": "29571005",
        "gender": "u"
      },
      "duration": 5.58
    },
    {
      "id": "29610100",
      "text": "Amalda “gaz zapravka”larda vaziyatni barqarorlashtirish uchun taklif ishlab chiqilmoqda.",
      "audio": "uz/unknown/uz_u_29610100.mp3",
      "tags": {
        "source_item_id": "29610100",
        "gender": "u"
      },
      "duration": 6.7
    },
    {
      "id": "29583064",
      "text": "Uni chin qalbdan taqdim etmadim.",
      "audio": "uz/unknown/uz_u_29583064.mp3",
      "tags": {
        "source_item_id": "29583064",
        "gender": "u"
      },
      "duration": 3.46
    },
    {
      "id": "29610979",
      "text": "Berdimuhamedov Ashxoboddagi Maxtumquli yodgorligi qurilishiga tashrif buyurdi",
      "audio": "uz/unknown/uz_u_29610979.mp3",
      "tags": {
        "source_item_id": "29610979",
        "gender": "u"
      },
      "duration": 6.3
    },
    {
      "id": "29408871",
      "text": "Talablaringiz juda yuqori ekanligidan afsuslanmang",
      "audio": "uz/unknown/uz_u_29408871.mp3",
      "tags": {
        "source_item_id": "29408871",
        "gender": "u"
      },
      "duration": 4.36
    },
    {
      "id": "28907414",
      "text": "Ular ustida unchalik ilhom bilan ishlamaganimni aytdim.",
      "audio": "uz/unknown/uz_u_28907414.mp3",
      "tags": {
        "source_item_id": "28907414",
        "gender": "u"
      },
      "duration": 5.08
    },
    {
      "id": "29037180",
      "text": "Xitoyning internetga nisbatan cheklovlari dunyoning boshqa barcha mamlakatlariga qaraganda ancha keng va murakkabdir.",
      "audio": "uz/unknown/uz_u_29037180.mp3",
      "tags": {
        "source_item_id": "29037180",
        "gender": "u"
      },
      "duration": 8.28
    },
    {
      "id": "29327617",
      "text": "homiylikka olish, ular uchun maktablar ochishga chaqiradi.",
      "audio": "uz/unknown/uz_u_29327617.mp3",
      "tags": {
        "source_item_id": "29327617",
        "gender": "u"
      },
      "duration": 4.0
    },
    {
      "id": "29556101",
      "text": "Biz uni Zoya xolamiz, der edik.",
      "audio": "uz/unknown/uz_u_29556101.mp3",
      "tags": {
        "source_item_id": "29556101",
        "gender": "u"
      },
      "duration": 4.14
    },
    {
      "id": "29610397",
      "text": "C vitaminiga boy tabiiy mahsulotlar",
      "audio": "uz/unknown/uz_u_29610397.mp3",
      "tags": {
        "source_item_id": "29610397",
        "gender": "u"
      },
      "duration": 5.15
    },
    {
      "id": "30177887",
      "text": "Johil elga qaramas.",
      "audio": "uz/unknown/uz_u_30177887.mp3",
      "tags": {
        "source_item_id": "30177887",
        "gender": "u"
      },
      "duration": 2.2
    },
    {
      "id": "29672859",
      "text": "Bola bu xabarni eshitib, esankiradi",
      "audio": "uz/unknown/uz_u_29672859.mp3",
      "tags": {
        "source_item_id": "29672859",
        "gender": "u"
      },
      "duration": 3.46
    }
  ]
}
