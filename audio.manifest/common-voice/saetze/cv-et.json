  "items": [
    {
      "id": "18138127",
      "text": "Kui sellist lihtsustamist nimetatakse maailmavaateks, siis võin mina end nimetada Taani printsiks.",
      "audio": "et/unknown/et_u_18138127.mp3",
      "tags": {
        "source_item_id": "18138127",
        "gender": "u"
      },
      "duration": 6.34
    },
    {
      "id": "18138703",
      "text": "Fännidel on põhjust olla pettunud.",
      "audio": "et/unknown/et_u_18138703.mp3",
      "tags": {
        "source_item_id": "18138703",
        "gender": "u"
      },
      "duration": 3.46
    },
    {
      "id": "18139451",
      "text": "See on olnud kogudusele hästi suur abi ja oleme selle toetuse eest väga tänulikud.",
      "audio": "et/unknown/et_u_18139451.mp3",
      "tags": {
        "source_item_id": "18139451",
        "gender": "u"
      },
      "duration": 5.74
    },
    {
      "id": "18146846",
      "text": "Sealjuures Keskerakonna fraktsiooni liikmed ei varjagi, et tegu on kättemaksuga, kirjutab ERRi uudisportaal.",
      "audio": "et/unknown/et_u_18146846.mp3",
      "tags": {
        "source_item_id": "18146846",
        "gender": "u"
      },
      "duration": 7.66
    },
    {
      "id": "18146987",
      "text": "Toona peeti vajalikuks seda otsust avalikult mitte rõhutada.",
      "audio": "et/unknown/et_u_18146987.mp3",
      "tags": {
        "source_item_id": "18146987",
        "gender": "u"
      },
      "duration": 4.9
    },
    {
      "id": "18147429",
      "text": "Grillimise hooaeg on täiega käimas ja seetõttu tasub kutsuda kõiki grillisõpru ettevaatusele.",
      "audio": "et/unknown/et_u_18147429.mp3",
      "tags": {
        "source_item_id": "18147429",
        "gender": "u"
      },
      "duration": 6.5
    },
    {
      "id": "18157812",
      "text": "Uue süüdlasekandidaadina toovad teadlased nüüd välja hoopis muutunud kliima, mis megafauna järk-järgult välja suretas.",
      "audio": "et/unknown/et_u_18157812.mp3",
      "tags": {
        "source_item_id": "18157812",
        "gender": "u"
      },
      "duration": 8.78
    },
    {
      "id": "18177896",
      "text": "Üksus peab olema valmis massiliste korratuste lahendamiseks.",
      "audio": "et/unknown/et_u_18177896.mp3",
      "tags": {
        "source_item_id": "18177896",
        "gender": "u"
      },
      "duration": 5.3
    },
    {
      "id": "18178034",
      "text": "Kui kesklinnas täidab bussi sumisev inimsülem, siis Viimsis saabub pärast uste avamist vaikus.",
      "audio": "et/unknown/et_u_18178034.mp3",
      "tags": {
        "source_item_id": "18178034",
        "gender": "u"
      },
      "duration": 7.54
    },
    {
      "id": "18181996",
      "text": "B-vitamiini puuduse peamiseks tunnuseks ongi väsimus ja meeleolumuutused.",
      "audio": "et/unknown/et_u_18181996.mp3",
      "tags": {
        "source_item_id": "18181996",
        "gender": "u"
      },
      "duration": 5.9
    }
  ]
}
