  "items": [
    {
      "id": "20433064",
      "text": "Να χαλάσω τελειωμένη δουλειά; είπε μελαγχολικά.",
      "audio": "el/unknown/el_u_20433064.mp3",
      "tags": {
        "source_item_id": "20433064",
        "gender": "u"
      },
      "duration": 4.22
    },
    {
      "id": "20437844",
      "text": "Αυτό δε μας λέγει γιατί έφυγε ο γιος σου",
      "audio": "el/unknown/el_u_20437844.mp3",
      "tags": {
        "source_item_id": "20437844",
        "gender": "u"
      },
      "duration": 4.22
    },
    {
      "id": "20447802",
      "text": "Να το πάρεις, Κυρά μου, αποκρίθηκε χαρούμενος ο Βασιλιάς.",
      "audio": "el/unknown/el_u_20447802.mp3",
      "tags": {
        "source_item_id": "20447802",
        "gender": "u"
      },
      "duration": 6.34
    },
    {
      "id": "20536748",
      "text": "Σκέφθηκα πως πρέπει να μου φτιάσεις μια πρόχειρη γέφυρα.",
      "audio": "el/unknown/el_u_20536748.mp3",
      "tags": {
        "source_item_id": "20536748",
        "gender": "u"
      },
      "duration": 4.54
    },
    {
      "id": "20575544",
      "text": "βαστούσε από τη φούστα τη φουρκισμένη Πικρόχολη.",
      "audio": "el/unknown/el_u_20575544.mp3",
      "tags": {
        "source_item_id": "20575544",
        "gender": "u"
      },
      "duration": 5.06
    },
    {
      "id": "20576009",
      "text": "που γύρευε να ζημιώσει καλούς και ήσυχους νοικοκυρέους;",
      "audio": "el/unknown/el_u_20576009.mp3",
      "tags": {
        "source_item_id": "20576009",
        "gender": "u"
      },
      "duration": 4.82
    },
    {
      "id": "20750499",
      "text": "Μου είπαν πάλι πως ήταν το παλάτι του Βασιλιά.",
      "audio": "el/unknown/el_u_20750499.mp3",
      "tags": {
        "source_item_id": "20750499",
        "gender": "u"
      },
      "duration": 4.87
    },
    {
      "id": "21105373",
      "text": "είπε με το φαρδύ του χαμόγελο",
      "audio": "el/unknown/el_u_21105373.mp3",
      "tags": {
        "source_item_id": "21105373",
        "gender": "u"
      },
      "duration": 3.34
    },
    {
      "id": "21349442",
      "text": "Βρήκε μια φέτα και την άλέιψε με βούτυρο",
      "audio": "el/unknown/el_u_21349442.mp3",
      "tags": {
        "source_item_id": "21349442",
        "gender": "u"
      },
      "duration": 5.78
    },
    {
      "id": "24822921",
      "text": "Η Ειρηνούλα κοίταζε την κλωστή και τις βελόνες χωρίς να καταλαβαίνει.",
      "audio": "el/unknown/el_u_24822921.mp3",
      "tags": {
        "source_item_id": "24822921",
        "gender": "u"
      },
      "duration": 6.16
    }
  ]
}
