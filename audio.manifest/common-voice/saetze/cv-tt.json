  "items": [
    {
      "id": "17516346",
      "text": "Авыл малайлары белән дә таныштым.",
      "audio": "tt/unknown/tt_u_17516346.mp3",
      "tags": {
        "source_item_id": "17516346",
        "gender": "u",
        "up_votes": 2,
        "down_votes": 0
      },
      "duration": 2.78
    },
    {
      "id": "17520299",
      "text": "Баралар-баралар, бара торгач, барып җитәләр тагын да матуррак бер биек яр буена.",
      "audio": "tt/unknown/tt_u_17520299.mp3",
      "tags": {
        "source_item_id": "17520299",
        "gender": "u",
        "up_votes": 2,
        "down_votes": 0
      },
      "duration": 7.82
    },
    {
      "id": "18821591",
      "text": "Күңелдәге бар ризасызлыкны да тышка чыгарып булмый.",
      "audio": "tt/unknown/tt_u_18821591.mp3",
      "tags": {
        "source_item_id": "18821591",
        "gender": "u",
        "up_votes": 2,
        "down_votes": 0
      },
      "duration": 4.82
    },
    {
      "id": "17669977",
      "text": "Адәм кулыннан килә торган эш түгел.",
      "audio": "tt/unknown/tt_u_17669977.mp3",
      "tags": {
        "source_item_id": "17669977",
        "gender": "u",
        "up_votes": 2,
        "down_votes": 0
      },
      "duration": 3.5
    },
    {
      "id": "17431733",
      "text": "Болар тиз генә йортка кереп бикләнәләр.",
      "audio": "tt/unknown/tt_u_17431733.mp3",
      "tags": {
        "source_item_id": "17431733",
        "gender": "u",
        "up_votes": 2,
        "down_votes": 0
      },
      "duration": 2.98
    },
    {
      "id": "18886301",
      "text": "Ана — шәфкать диңгезе.",
      "audio": "tt/unknown/tt_u_18886301.mp3",
      "tags": {
        "source_item_id": "18886301",
        "gender": "u",
        "up_votes": 2,
        "down_votes": 0
      },
      "duration": 3.14
    },
    {
      "id": "17920174",
      "text": "Утыз тештән чыккан утыз илгә җәелә.",
      "audio": "tt/unknown/tt_u_17920174.mp3",
      "tags": {
        "source_item_id": "17920174",
        "gender": "u",
        "up_votes": 2,
        "down_votes": 0
      },
      "duration": 3.22
    },
    {
      "id": "17431710",
      "text": "Йокыдан уянгач, алманы яңадан санап карады, элек икәү юк иде, хәзер өчәү юк.",
      "audio": "tt/unknown/tt_u_17431710.mp3",
      "tags": {
        "source_item_id": "17431710",
        "gender": "u",
        "up_votes": 2,
        "down_votes": 1
      },
      "duration": 5.9
    },
    {
      "id": "17766357",
      "text": "Алар тырышлыгы белән ел дәвамында мәчет каршындагы мәдрәсәләрдә дини укулар оештырылган.",
      "audio": "tt/unknown/tt_u_17766357.mp3",
      "tags": {
        "source_item_id": "17766357",
        "gender": "u",
        "up_votes": 2,
        "down_votes": 0
      },
      "duration": 7.1
    },
    {
      "id": "17626690",
      "text": "Ул мине ярата.",
      "audio": "tt/unknown/tt_u_17626690.mp3",
      "tags": {
        "source_item_id": "17626690",
        "gender": "u",
        "up_votes": 2,
        "down_votes": 0
      },
      "duration": 2.06
    },
    {
      "id": "17630807",
      "text": "Әсәр шундый бәя алды.",
      "audio": "tt/unknown/tt_u_17630807.mp3",
      "tags": {
        "source_item_id": "17630807",
        "gender": "u",
        "up_votes": 2,
        "down_votes": 0
      },
      "duration": 2.42
    },
    {
      "id": "17343449",
      "text": "Теге аждаһалы елгага кайтып җитә.",
      "audio": "tt/unknown/tt_u_17343449.mp3",
      "tags": {
        "source_item_id": "17343449",
        "gender": "u",
        "up_votes": 2,
        "down_votes": 0
      },
      "duration": 3.86
    }
  ]
}
