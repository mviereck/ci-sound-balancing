  "items": [
    {
      "id": "23337868",
      "text": "ਸਿੱਖ ਕੌੰਮ ਨੂੰ ਜਗਾਉਣਾ ਕੋਈ ਮੁਸ਼ਕਲ ਨਹੀਂ",
      "audio": "pa-IN/unknown/pa-IN_u_23337868.mp3",
      "tags": {
        "source_item_id": "23337868",
        "gender": "u"
      },
      "duration": 5.86
    },
    {
      "id": "23391436",
      "text": "ਰਾਮ ਸਿੰਘ ਔਲਖ ਦਾ ਇਹ ਵੱਡਾ ਉਪਰਾਲਾ",
      "audio": "pa-IN/unknown/pa-IN_u_23391436.mp3",
      "tags": {
        "source_item_id": "23391436",
        "gender": "u"
      },
      "duration": 4.94
    },
    {
      "id": "23372250",
      "text": "ਉਹ ਭਗਤ ਕਿਸਮ ਦਾ ਸਿੱਧੜ ਬੰਦਾ ਸੀ",
      "audio": "pa-IN/unknown/pa-IN_u_23372250.mp3",
      "tags": {
        "source_item_id": "23372250",
        "gender": "u"
      },
      "duration": 4.56
    },
    {
      "id": "23381790",
      "text": "ਇਨ੍ਹਾਂ ਵਿਚ ਇਸਤਰੀ ਮੈਂਬਰ ਵੀ ਸ਼ਾਮਲ ਸਨ",
      "audio": "pa-IN/unknown/pa-IN_u_23381790.mp3",
      "tags": {
        "source_item_id": "23381790",
        "gender": "u"
      },
      "duration": 6.17
    },
    {
      "id": "23371102",
      "text": "ਜਿਊਂਦੇ ਨੀਹਾਂ ਚ ਦੋ ਖਲ੍ਹਾਰ ਦਿਤੇ",
      "audio": "pa-IN/unknown/pa-IN_u_23371102.mp3",
      "tags": {
        "source_item_id": "23371102",
        "gender": "u"
      },
      "duration": 4.3
    },
    {
      "id": "23391017",
      "text": "ਉਸ ਦੇ ਬਿਰਤਾਂਤ ਵਿੱਚ ਰਸ ਹੈ",
      "audio": "pa-IN/unknown/pa-IN_u_23391017.mp3",
      "tags": {
        "source_item_id": "23391017",
        "gender": "u"
      },
      "duration": 4.61
    },
    {
      "id": "23381865",
      "text": "ਧੁਖਦੇ ਮਨਾ ਵਿਚੋਂ ਨਿਕਲ ਰਿਹਾ ਧੂੰਆਂ ਹੈ",
      "audio": "pa-IN/unknown/pa-IN_u_23381865.mp3",
      "tags": {
        "source_item_id": "23381865",
        "gender": "u"
      },
      "duration": 6.55
    },
    {
      "id": "23382023",
      "text": "ਸੱਚ ਦੀ ਹਮੇਸ਼ਾ ਜੈ ਹੁੰਦੀ ਹੈ",
      "audio": "pa-IN/unknown/pa-IN_u_23382023.mp3",
      "tags": {
        "source_item_id": "23382023",
        "gender": "u"
      },
      "duration": 2.95
    },
    {
      "id": "23337992",
      "text": "ਪੜ੍ਹਾਈ ਲਿਖਾਈ ਵੱਲੋਂ ਉਹ ਅਸਲੋਂ ਕੋਰਾ ਹੈ",
      "audio": "pa-IN/unknown/pa-IN_u_23337992.mp3",
      "tags": {
        "source_item_id": "23337992",
        "gender": "u"
      },
      "duration": 4.56
    },
    {
      "id": "23371700",
      "text": "ਅਸੀਂ ਕੀਲੇ ਹੋਏ ਉਸਦੀਆਂ ਗੱਲਾਂ ਸੁਣਦੇ",
      "audio": "pa-IN/unknown/pa-IN_u_23371700.mp3",
      "tags": {
        "source_item_id": "23371700",
        "gender": "u"
      },
      "duration": 5.45
    },
    {
      "id": "23405487",
      "text": "ਅਸੀਂ ਤੁਹਾਨੂੰ ਅਗਾਊਂ ਸੱਦਾ ਦਿੰਨੇ ਆਂ",
      "audio": "pa-IN/unknown/pa-IN_u_23405487.mp3",
      "tags": {
        "source_item_id": "23405487",
        "gender": "u"
      },
      "duration": 5.23
    }
  ]
}
