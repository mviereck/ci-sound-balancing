  "items": [
    {
      "id": "33577624",
      "text": "ፔድሮ ሞቶሳይክል ኣላቶ፣ ንዓኣ ክዝውራ ይፈቱ እዩ።",
      "audio": "ti/unknown/ti_u_33577624.mp3",
      "tags": {
        "source_item_id": "33577624",
        "gender": "u"
      },
      "duration": 7.31
    },
    {
      "id": "35049772",
      "text": "ርእሰይ ስለ ዝሓመምኩ፡ ክገብሮ ኣይከኣልኩን።",
      "audio": "ti/unknown/ti_u_35049772.mp3",
      "tags": {
        "source_item_id": "35049772",
        "gender": "u"
      },
      "duration": 4.61
    },
    {
      "id": "35049766",
      "text": "ቻርሊ፡ ነቲ ጥርሙዝ ሻምፓኝ ናብቲ መንደቅ ሓምሽሽዎ።",
      "audio": "ti/unknown/ti_u_35049766.mp3",
      "tags": {
        "source_item_id": "35049766",
        "gender": "u"
      },
      "duration": 5.58
    },
    {
      "id": "35049776",
      "text": "ሃሪ ጽቡቕ ገይሩ እዩ ከበሮ ዝሃርም።",
      "audio": "ti/unknown/ti_u_35049776.mp3",
      "tags": {
        "source_item_id": "35049776",
        "gender": "u"
      },
      "duration": 3.28
    },
    {
      "id": "33577625",
      "text": "ጆ ኣበይ ከምዝተወልደ ኣይፈልጥን እዩ።",
      "audio": "ti/unknown/ti_u_33577625.mp3",
      "tags": {
        "source_item_id": "33577625",
        "gender": "u"
      },
      "duration": 5.29
    },
    {
      "id": "35049775",
      "text": "ዓሚ ኣብ ቻይና ነይረ።",
      "audio": "ti/unknown/ti_u_35049775.mp3",
      "tags": {
        "source_item_id": "35049775",
        "gender": "u"
      },
      "duration": 3.28
    },
    {
      "id": "33577627",
      "text": "ኣብ ህዝባዊ ሰውራ ኣይተሳተፉን።",
      "audio": "ti/unknown/ti_u_33577627.mp3",
      "tags": {
        "source_item_id": "33577627",
        "gender": "u"
      },
      "duration": 5.11
    },
    {
      "id": "35049764",
      "text": "ከምዚ ኣንጸባራቒ ኩኾብ ርእየ ኣይፈልጥን እየ።",
      "audio": "ti/unknown/ti_u_35049764.mp3",
      "tags": {
        "source_item_id": "35049764",
        "gender": "u"
      },
      "duration": 5.44
    },
    {
      "id": "35049763",
      "text": "ኩባንያና፡ ናይ ሽሕ ሚልዮን የን ዓመታዊ መሸጣ ኣለዎ።",
      "audio": "ti/unknown/ti_u_35049763.mp3",
      "tags": {
        "source_item_id": "35049763",
        "gender": "u"
      },
      "duration": 6.3
    },
    {
      "id": "35049762",
      "text": "ካብ ጤል ብእተሰርሐ ፎርማጆ ንእተዳለወ ፓኒኖ በሊዑ።",
      "audio": "ti/unknown/ti_u_35049762.mp3",
