      "duration": 6.46
    },
    {
      "id": "17374922",
      "text": "Lloa el mar i viu en terra.",
      "audio": "ca/unknown/ca_u_17374922.mp3",
      "tags": {
        "source_item_id": "17374922",
        "gender": "u",
        "up_votes": 4,
