  "items": [
    {
      "id": "28722079",
      "text": "Syns denne boka blei litt usamanhengande og springande.",
      "audio": "nn-NO/unknown/nn-NO_u_28722079.mp3",
      "tags": {
        "source_item_id": "28722079",
        "gender": "u"
      },
      "duration": 5.8
    },
    {
      "id": "37294404",
      "text": "Utan slikt fanns her ikkje godvèr.",
      "audio": "nn-NO/unknown/nn-NO_u_37294404_s_rlandet_s_rl_nding_southern_southern_norway.mp3",
      "tags": {
        "source_item_id": "37294404",
        "gender": "u",
        "accent": "Sørlandet,Sørlænding,Southern,Southern Norway"
      },
      "duration": 3.24
    },
    {
      "id": "38529956",
      "text": "Ho visste inderleg godt at det var onsdag i dag.",
      "audio": "nn-NO/unknown/nn-NO_u_38529956_sunnhordland.mp3",
      "tags": {
        "source_item_id": "38529956",
        "gender": "u",
        "accent": "sunnhordland"
      },
      "duration": 3.85
    },
    {
      "id": "37296667",
      "text": "Underleg at ikkje dette får større plass.",
      "audio": "nn-NO/unknown/nn-NO_u_37296667_s_rlandet_s_rl_nding_southern_southern_norway.mp3",
      "tags": {
        "source_item_id": "37296667",
        "gender": "u",
        "accent": "Sørlandet,Sørlænding,Southern,Southern Norway"
      },
      "duration": 3.64
    },
    {
      "id": "38530401",
      "text": "Kan jo vera at du vart påverka av det tomme ekteskapet..",
      "audio": "nn-NO/unknown/nn-NO_u_38530401_sunnhordland.mp3",
      "tags": {
        "source_item_id": "38530401",
        "gender": "u",
        "accent": "sunnhordland"
      },
      "duration": 3.96
    },
    {
      "id": "30329703",
      "text": "Ikkje ein regel utan unntak.",
      "audio": "nn-NO/unknown/nn-NO_u_30329703.mp3",
      "tags": {
        "source_item_id": "30329703",
        "gender": "u"
      },
      "duration": 3.96
    },
    {
      "id": "28722084",
      "text": "Eg vil fortelja og syngja om ting",
      "audio": "nn-NO/unknown/nn-NO_u_28722084.mp3",
      "tags": {
        "source_item_id": "28722084",
        "gender": "u"
      },
      "duration": 4.07
    },
    {
      "id": "38530424",
      "text": "Det finst bøker som eg faktisk ikkje kjem til å sakne.",
      "audio": "nn-NO/unknown/nn-NO_u_38530424_sunnhordland.mp3",
      "tags": {
        "source_item_id": "38530424",
        "gender": "u",
        "accent": "sunnhordland"
      },
      "duration": 3.89
    },
    {
      "id": "38530065",
      "text": "For nokre år sidan var eg i bokbyen Fjærland.",
      "audio": "nn-NO/unknown/nn-NO_u_38530065_sunnhordland.mp3",
      "tags": {
        "source_item_id": "38530065",
        "gender": "u",
        "accent": "sunnhordland"
      },
      "duration": 3.82
    },
    {
      "id": "37294407",
      "text": "Her blei det litt for tjukk glasur etter kvart.",
      "audio": "nn-NO/unknown/nn-NO_u_37294407_s_rlandet_s_rl_nding_southern_southern_norway.mp3",
      "tags": {
        "source_item_id": "37294407",
        "gender": "u",
        "accent": "Sørlandet,Sørlænding,Southern,Southern Norway"
      },
      "duration": 3.24
    },
    {
      "id": "37294824",
      "text": "Men dette kjem ikkje brått.",
      "audio": "nn-NO/unknown/nn-NO_u_37294824_s_rlandet_s_rl_nding_southern_southern_norway.mp3",
      "tags": {
        "source_item_id": "37294824",
        "gender": "u",
        "accent": "Sørlandet,Sørlænding,Southern,Southern Norway"
      },
      "duration": 2.74
    },
    {
      "id": "37296287",
      "text": "Eg har sett båe sider no",
      "audio": "nn-NO/unknown/nn-NO_u_37296287_s_rlandet_s_rl_nding_southern_southern_norway.mp3",
      "tags": {
        "source_item_id": "37296287",
        "gender": "u",
        "accent": "Sørlandet,Sørlænding,Southern,Southern Norway"
      },
      "duration": 2.52
    },
    {
      "id": "28806239",
      "text": "På skjermen - som iallfall irriterer meg når eg les.",
      "audio": "nn-NO/unknown/nn-NO_u_28806239.mp3",
      "tags": {
        "source_item_id": "28806239",
        "gender": "u"
      },
      "duration": 5.4
    }
  ]
}
