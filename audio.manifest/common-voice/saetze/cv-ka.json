      "duration": 7.02
    },
    {
      "id": "34258272",
      "text": "ამის შემდეგ დიდი ხანი რომაელი ხალხისთვის მეფის მმართველობაზე საძულველი და დამამცირებელი ალბათ არაფერი იყო.",
      "audio": "ka/unknown/ka_u_34258272.mp3",
