      }
    },
    {
      "id": "19644804",
      "text": "Roedd yn gyffrous medru gweld y bwyd yn cael ei goginio hefyd.",
      "audio": "cy/unknown/cy_u_19644804.mp3",
      "tags": {
        "source_item_id": "19644804",
        "gender": "u"
      }
    },
    {
      "id": "19684386",
      "text": "Nid ydyw Awst wedi darfod.",
