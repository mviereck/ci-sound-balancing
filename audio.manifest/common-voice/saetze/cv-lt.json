  "items": [
    {
      "id": "23705775",
      "text": "Leido ir redagavo Aleksandras Burba.",
      "audio": "lt/unknown/lt_u_23705775.mp3",
      "tags": {
        "source_item_id": "23705775",
        "gender": "u",
        "up_votes": 2,
        "down_votes": 0
      },
      "duration": 3.41
    },
    {
      "id": "23716959",
      "text": "Įteka į Karibų jūrą ties Padėkos Dievui kyšuliu.",
      "audio": "lt/unknown/lt_u_23716959.mp3",
      "tags": {
        "source_item_id": "23716959",
        "gender": "u",
        "up_votes": 2,
        "down_votes": 0
      },
      "duration": 5.71
    },
    {
      "id": "23754688",
      "text": "Tarptautinių ir rusiškų šaškių kandidatas į sporto meistrus.",
      "audio": "lt/unknown/lt_u_23754688.mp3",
      "tags": {
        "source_item_id": "23754688",
        "gender": "u",
        "up_votes": 2,
        "down_votes": 0
      },
      "duration": 7.42
    },
    {
      "id": "25114586",
      "text": "Tuo pačiu Italijoje cirkuliavo ir San Marino lira bei Vatikano lira.",
      "audio": "lt/unknown/lt_u_25114586.mp3",
      "tags": {
        "source_item_id": "25114586",
        "gender": "u",
        "up_votes": 2,
        "down_votes": 0
      },
      "duration": 8.32
    },
    {
      "id": "25114729",
      "text": "Tuo metu bendruomenė tapo smurto ir konfliktų arena tarp bendruomenės narių.",
      "audio": "lt/unknown/lt_u_25114729.mp3",
      "tags": {
        "source_item_id": "25114729",
        "gender": "u",
        "up_votes": 2,
        "down_votes": 0
      },
      "duration": 6.41
    },
    {
      "id": "25132803",
      "text": "Joje žiemoja retai arba atsitiktinai.",
      "audio": "lt/unknown/lt_u_25132803.mp3",
      "tags": {
        "source_item_id": "25132803",
        "gender": "u",
        "up_votes": 2,
        "down_votes": 0
      },
      "duration": 4.14
    },
    {
      "id": "25151454",
      "text": "Netrukus įvykusiuose parlamento rinkimuose Liaudies partija pralaimėjo socialistams.",
      "audio": "lt/unknown/lt_u_25151454.mp3",
      "tags": {
        "source_item_id": "25151454",
        "gender": "u",
        "up_votes": 2,
        "down_votes": 0
      },
      "duration": 9.04
    },
    {
      "id": "36949075",
      "text": "Ši direkcija tiesiogiai pavaldi Prancūzijos vidaus reikalų ministrui.",
      "audio": "lt/unknown/lt_u_36949075.mp3",
      "tags": {
        "source_item_id": "36949075",
        "gender": "u",
        "up_votes": 2,
        "down_votes": 0
      },
      "duration": 6.66
    },
    {
      "id": "36953319",
      "text": "Aplinkui plyti pievos ir dirbami laukai.",
      "audio": "lt/unknown/lt_u_36953319.mp3",
      "tags": {
        "source_item_id": "36953319",
