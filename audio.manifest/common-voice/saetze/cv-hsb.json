  "items": [
    {
      "id": "20359372",
      "text": "Z prěnim wobzamknjenjom je sejmik nowu wersiju wozjewjenskich wustawkow wobzamknył.",
      "audio": "hsb/unknown/hsb_u_20359372.mp3",
      "tags": {
        "source_item_id": "20359372",
        "gender": "u",
        "up_votes": 2,
        "down_votes": 0
      },
      "duration": 7.58
    },
    {
      "id": "20404861",
      "text": "Tak hodźeli so wobstejace synergije wužiwać.",
      "audio": "hsb/unknown/hsb_u_20404861.mp3",
      "tags": {
        "source_item_id": "20404861",
        "gender": "u",
        "up_votes": 2,
        "down_votes": 0
      },
      "duration": 4.58
    },
    {
      "id": "20369058",
      "text": "Ty bě tołsta, dokelž sy přewjele słódkosćow jědła.",
      "audio": "hsb/unknown/hsb_u_20369058.mp3",
      "tags": {
        "source_item_id": "20369058",
        "gender": "u",
        "up_votes": 2,
        "down_votes": 0
      },
      "duration": 5.38
    },
    {
      "id": "20359374",
      "text": "Tójšto zarjadowanjow wotmě so w małoměstach a na wsach.",
      "audio": "hsb/unknown/hsb_u_20359374.mp3",
      "tags": {
        "source_item_id": "20359374",
        "gender": "u",
        "up_votes": 2,
        "down_votes": 0
      },
      "duration": 6.34
    },
    {
      "id": "20367430",
      "text": "Wón skutkuje tež jako solo-gitarist na koncertach we Łužicy a zwonka njeje.",
      "audio": "hsb/unknown/hsb_u_20367430.mp3",
      "tags": {
        "source_item_id": "20367430",
        "gender": "u",
        "up_votes": 2,
        "down_votes": 0
      },
      "duration": 8.42
    },
    {
      "id": "20492850",
      "text": "Klimowi aktiwisća su wčera před čěskim wobswětowym ministerstwom přećiwo dalšemu wudobywanju brunicy protestowali.",
      "audio": "hsb/unknown/hsb_u_20492850.mp3",
      "tags": {
        "source_item_id": "20492850",
        "gender": "u",
        "up_votes": 2,
        "down_votes": 0
      },
      "duration": 9.02
    },
    {
      "id": "20367464",
      "text": "Wonej chcyštej z wowku hodowne dariki nakupować hić.",
      "audio": "hsb/unknown/hsb_u_20367464.mp3",
      "tags": {
        "source_item_id": "20367464",
        "gender": "u",
        "up_votes": 2,
        "down_votes": 0
      },
      "duration": 5.14
    },
    {
      "id": "20952081",
      "text": "Šula njeměješe jenož dwě rjadowni, ale samo štyri.",
      "audio": "hsb/unknown/hsb_u_20952081.mp3",
      "tags": {
        "source_item_id": "20952081",
        "gender": "u",
        "up_votes": 2,
        "down_votes": 0
      },
      "duration": 5.66
    },
    {
      "id": "20376680",
      "text": "Pućowacy zeznaja tak rozdźělne kónčiny a njeličomne zajimawostki.",
      "audio": "hsb/unknown/hsb_u_20376680.mp3",
      "tags": {
        "source_item_id": "20376680",
        "gender": "u",
        "up_votes": 2,
        "down_votes": 0
      },
      "duration": 5.9
    },
    {
      "id": "20359330",
      "text": "Woni běchu w měsće a nětko po puću domoj.",
      "audio": "hsb/unknown/hsb_u_20359330.mp3",
      "tags": {
        "source_item_id": "20359330",
        "gender": "u",
        "up_votes": 2,
        "down_votes": 0
      },
      "duration": 4.78
    },
    {
      "id": "20369204",
      "text": "Tež tónraz chcedźa serbske nałožki, tradicije a rěč Hanza Njepile zjawnosći předstajić.",
