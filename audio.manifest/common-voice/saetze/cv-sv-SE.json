  "items": [
    {
      "id": "18711970",
      "text": "Jo, jag tittar på den nu.",
      "audio": "sv-SE/unknown/sv-SE_u_18711970.mp3",
      "tags": {
        "source_item_id": "18711970",
        "gender": "u"
      }
    },
    {
      "id": "18737942",
      "text": "För att du har så dålig musiksmak.",
      "audio": "sv-SE/unknown/sv-SE_u_18737942_rikssvenska_sveam_l_stockholmska_skelleftem_l.mp3",
      "tags": {
        "source_item_id": "18737942",
        "gender": "u",
        "accent": "Rikssvenska,Sveamål,Stockholmska,Skelleftemål"
      }
    },
    {
      "id": "18747822",
      "text": "Vi klarar oss tills grödorna har grott.",
      "audio": "sv-SE/unknown/sv-SE_u_18747822.mp3",
      "tags": {
        "source_item_id": "18747822",
        "gender": "u"
      }
    },
    {
      "id": "18844791",
      "text": "Är jag dess rättmätige ägare.",
      "audio": "sv-SE/unknown/sv-SE_u_18844791.mp3",
      "tags": {
        "source_item_id": "18844791",
        "gender": "u"
      }
    },
    {
      "id": "18847619",
      "text": "Han gick i min klass.",
      "audio": "sv-SE/unknown/sv-SE_u_18847619.mp3",
      "tags": {
        "source_item_id": "18847619",
        "gender": "u"
      }
    },
    {
      "id": "18848640",
      "text": "Du kan döda oss båda senare.",
      "audio": "sv-SE/unknown/sv-SE_u_18848640.mp3",
      "tags": {
        "source_item_id": "18848640",
        "gender": "u"
      }
    },
    {
      "id": "19101551",
      "text": "Innan var hon läkare på en kasern.",
      "audio": "sv-SE/unknown/sv-SE_u_19101551.mp3",
      "tags": {
        "source_item_id": "19101551",
        "gender": "u"
      }
    },
    {
      "id": "19518501",
      "text": "Han är liten och jättesöt.",
      "audio": "sv-SE/unknown/sv-SE_u_19518501.mp3",
      "tags": {
        "source_item_id": "19518501",
        "gender": "u"
      }
    },
    {
      "id": "20020962",
      "text": "Den var vidrig och korkad.",
      "audio": "sv-SE/unknown/sv-SE_u_20020962.mp3",
      "tags": {
        "source_item_id": "20020962",
        "gender": "u"
      }
    },
    {
      "id": "20171301",
      "text": "Vi måste få fram en massa pengar.",
      "audio": "sv-SE/unknown/sv-SE_u_20171301.mp3",
      "tags": {
        "source_item_id": "20171301",
        "gender": "u"
      }
    }
  ]
}
