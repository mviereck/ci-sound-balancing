        "accent": "Erdialdekoa edo Nafarra (Gipuzkoa, Nafarroa)",
        "up_votes": 2,
        "down_votes": 1
      },
      "duration": 7.34
    },
    {
      "id": "18257136",
      "text": "Lana bukatzean kirola hasten da eta kirola bukatzean lana.",
      "audio": "eu/unknown/eu_u_18257136_erdialdekoa_edo_nafarra_gipuzkoa_nafarroa.mp3",
      "tags": {
        "source_item_id": "18257136",
