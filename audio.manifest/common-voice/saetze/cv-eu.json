      },
      "duration": 4.3
    },
    {
      "id": "18333502",
      "text": "Santxok horrela definitu du Bilboko sarearen helburua.",
      "audio": "eu/unknown/eu_u_18333502_erdialdekoa_edo_nafarra_gipuzkoa_nafarroa.mp3",
      "tags": {
        "source_item_id": "18333502",
