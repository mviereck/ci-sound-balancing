      },
      "duration": 6.62
    },
    {
      "id": "18346581",
      "text": "Gozatu zuten hazkunde ekonomiko eta bizi-baldintzen hobekuntza aldian.",
      "audio": "eu/unknown/eu_u_18346581_mendebalekoa_araka_bizkaia_gipuzkoako_mendebaleko_herri_batzuk.mp3",
      "tags": {
        "source_item_id": "18346581",
