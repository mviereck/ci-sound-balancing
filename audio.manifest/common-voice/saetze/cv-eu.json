        "up_votes": 2,
        "down_votes": 0
      },
      "duration": 7.1
    },
    {
      "id": "18275742",
      "text": "Haiek urteak daramatzate kalean bizitzen.",
      "audio": "eu/unknown/eu_u_18275742_erdialdekoa_edo_nafarra_gipuzkoa_nafarroa.mp3",
      "tags": {
        "source_item_id": "18275742",
        "gender": "u",
        "accent": "Erdialdekoa edo Nafarra (Gipuzkoa, Nafarroa)",
        "up_votes": 2,
        "down_votes": 1
      },
      "duration": 3.65
    },
    {
      "id": "18282921",
      "text": "Buztana ukitu duenak, soka itxura ematen dio elefanteari.",
      "audio": "eu/unknown/eu_u_18282921_mendebalekoa_araka_bizkaia_gipuzkoako_mendebaleko_herri_batzuk.mp3",
      "tags": {
        "source_item_id": "18282921",
        "gender": "u",
        "accent": "Mendebalekoa (Araka, Bizkaia, Gipuzkoako mendebaleko herri batzuk)",
        "up_votes": 2,
        "down_votes": 0
      },
      "duration": 6.17
    },
    {
      "id": "18307320",
      "text": "Gu jada estatutik kanpo kokatzen gara.",
      "audio": "eu/unknown/eu_u_18307320_mendebalekoa_araka_bizkaia_gipuzkoako_mendebaleko_herri_batzuk.mp3",
      "tags": {
