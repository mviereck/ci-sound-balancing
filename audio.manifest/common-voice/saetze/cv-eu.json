        "up_votes": 2,
        "down_votes": 0
      },
      "duration": 6.29
    },
    {
      "id": "18257021",
      "text": "Gure musikak eta hitzak gaur egungo pasibotasunaren inarrosteko sortzen ditugu.",
      "audio": "eu/unknown/eu_u_18257021_erdialdekoa_edo_nafarra_gipuzkoa_nafarroa.mp3",
      "tags": {
        "source_item_id": "18257021",
