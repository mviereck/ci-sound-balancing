  "items": [
    {
      "id": "32613356",
      "text": "Sos diacrìticos tenent unu significadu fonèticu, semànticu e etimològicu.",
      "audio": "sc/unknown/sc_u_32613356_campidanesu.mp3",
      "tags": {
        "source_item_id": "32613356",
        "gender": "u",
        "accent": "Campidanesu"
      },
      "duration": 7.85
    },
    {
      "id": "33349239",
      "text": "Su delitu diferente dae su restu de Sardigna est sa fura pro iscòrriu.",
      "audio": "sc/unknown/sc_u_33349239.mp3",
      "tags": {
        "source_item_id": "33349239",
        "gender": "u"
      },
      "duration": 4.68
    },
    {
      "id": "33351429",
      "text": "Nessi cussa chi est in Cussìgiu Regionale.",
      "audio": "sc/unknown/sc_u_33351429.mp3",
      "tags": {
        "source_item_id": "33351429",
        "gender": "u"
      },
      "duration": 2.92
    },
    {
      "id": "32889042",
      "text": "Totus amus dèpidu rinuntziare a carchi cosa, fortzis prus de is àteros puru.",
      "audio": "sc/unknown/sc_u_32889042_campidanesu.mp3",
      "tags": {
        "source_item_id": "32889042",
        "gender": "u",
        "accent": "Campidanesu"
      },
      "duration": 6.88
    },
    {
      "id": "32627895",
      "text": "Immoi so bidende pipios o giòvanos de sas biddas chi chistionant in italianu.",
      "audio": "sc/unknown/sc_u_32627895_campidanesu.mp3",
      "tags": {
        "source_item_id": "32627895",
        "gender": "u",
        "accent": "Campidanesu"
      },
      "duration": 6.41
    },
    {
      "id": "33351911",
      "text": "Amus atobiadu a Sandro Puggioni, mere de s'azienda.",
      "audio": "sc/unknown/sc_u_33351911.mp3",
      "tags": {
        "source_item_id": "33351911",
        "gender": "u"
      },
      "duration": 4.07
    },
    {
      "id": "32638459",
      "text": "Fiat fìgiu de sa mugere de su re.",
      "audio": "sc/unknown/sc_u_32638459_campidanesu.mp3",
      "tags": {
        "source_item_id": "32638459",
        "gender": "u",
        "accent": "Campidanesu"
      },
      "duration": 4.18
    },
    {
      "id": "32889711",
      "text": "Ma sunt cosas diferentes.",
      "audio": "sc/unknown/sc_u_32889711_campidanesu.mp3",
      "tags": {
        "source_item_id": "32889711",
        "gender": "u",
        "accent": "Campidanesu"
      },
      "duration": 3.35
    },
    {
      "id": "33351884",
      "text": "Gasi dughentas persones contant pro unu sòtziu.",
      "audio": "sc/unknown/sc_u_33351884.mp3",
      "tags": {
        "source_item_id": "33351884",
        "gender": "u"
      },
      "duration": 3.49
    },
    {
      "id": "32630930",
      "text": "Lu depimus amìtere.",
      "audio": "sc/unknown/sc_u_32630930_campidanesu.mp3",
      "tags": {
        "source_item_id": "32630930",
        "gender": "u",
        "accent": "Campidanesu"
      },
      "duration": 3.64
    },
    {
      "id": "33351161",
      "text": "Sos pratos preferidos no los agradessides prus.",
      "audio": "sc/unknown/sc_u_33351161.mp3",
      "tags": {
        "source_item_id": "33351161",
        "gender": "u"
      },
      "duration": 3.2
    },
    {
      "id": "33351585",
      "text": "Est su de tres annos chi s’iscola tataresa partètzipat a su progetu.",
      "audio": "sc/unknown/sc_u_33351585.mp3",
      "tags": {
        "source_item_id": "33351585",
        "gender": "u"
      },
      "duration": 4.93
    }
  ]
}
