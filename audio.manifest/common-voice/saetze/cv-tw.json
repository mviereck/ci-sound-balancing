  "items": [
    {
      "id": "35280492",
      "text": "Ná wasi gyinae a etwa to.",
      "audio": "tw/unknown/tw_u_35280492_native.mp3",
      "tags": {
        "source_item_id": "35280492",
        "gender": "u",
        "accent": "Native"
      },
      "duration": 3.42
    },
    {
      "id": "35292449",
      "text": "Me ne no traa dan biako mu.",
      "audio": "tw/unknown/tw_u_35292449_native.mp3",
      "tags": {
        "source_item_id": "35292449",
        "gender": "u",
        "accent": "Native"
      },
      "duration": 2.92
    },
    {
      "id": "35280546",
      "text": "Wɔtɔn Asetra a Enni Awiei",
      "audio": "tw/unknown/tw_u_35280546_native.mp3",
      "tags": {
        "source_item_id": "35280546",
        "gender": "u",
        "accent": "Native"
      },
      "duration": 3.64
    },
    {
      "id": "35292434",
      "text": "Ahude Ho Anigye a Wɔkyerɛ",
      "audio": "tw/unknown/tw_u_35292434_native.mp3",
      "tags": {
        "source_item_id": "35292434",
        "gender": "u",
        "accent": "Native"
      },
      "duration": 3.17
    },
    {
      "id": "35292427",
      "text": "Nhwehwɛmufo foforo nnye saa nneɛma a wɔahu yi ntom.",
      "audio": "tw/unknown/tw_u_35292427_native.mp3",
      "tags": {
        "source_item_id": "35292427",
        "gender": "u",
        "accent": "Native"
      },
      "duration": 4.5
    },
    {
      "id": "35292440",
      "text": "Ɔkwan no so ankasa na menam yi? ’",
      "audio": "tw/unknown/tw_u_35292440_native.mp3",
      "tags": {
        "source_item_id": "35292440",
        "gender": "u",
        "accent": "Native"
      },
      "duration": 3.28
    },
    {
      "id": "35280548",
      "text": "German kasa ho nimdeɛ a mewɔ no sua.",
      "audio": "tw/unknown/tw_u_35280548_native.mp3",
      "tags": {
        "source_item_id": "35280548",
        "gender": "u",
        "accent": "Native"
      },
      "duration": 4.0
    },
    {
      "id": "35280547",
      "text": "Mehwɛ kwan sɛ ɔbɛba bere biara.",
      "audio": "tw/unknown/tw_u_35280547_native.mp3",
      "tags": {
        "source_item_id": "35280547",
        "gender": "u",
        "accent": "Native"
      },
      "duration": 3.28
    },
    {
      "id": "35292425",
      "text": "mɛyɛ deɛ metumi biara.",
      "audio": "tw/unknown/tw_u_35292425_native.mp3",
      "tags": {
        "source_item_id": "35292425",
        "gender": "u",
        "accent": "Native"
      },
      "duration": 2.34
    },
    {
      "id": "35280594",
      "text": "Me ne no gyee nhyehyɛe foforow no ho akyinnye.",
      "audio": "tw/unknown/tw_u_35280594_native.mp3",
      "tags": {
        "source_item_id": "35280594",
        "gender": "u",
        "accent": "Native"
      },
      "duration": 4.14
    },
    {
      "id": "35292437",
      "text": "Nkurɔfo kae sɛ wabɔ dam.",
      "audio": "tw/unknown/tw_u_35292437_native.mp3",
      "tags": {
        "source_item_id": "35292437",
